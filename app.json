{
  "expo": {
    "name": "Skyinventories",
    "slug": "skyline-app",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon-2.png",
    "scheme": "skyinventories",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c8e9edc6-e561-422c-b8bc-576d4ebc2c82",
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD",
      "channel": "production"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.skyinventories",
      "icon": "./assets/images/ios-icon.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#008BD6",
        "foregroundImage": "./assets/images/app-icon-2.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.skyinventories"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon-5.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#008BD6",
          "dark": {
            "backgroundColor": "#008BD6"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Skyinventories needs camera access to scan barcodes for shipments and inventory.",
          "microphonePermission": "Skyinventories may use the microphone while scanning if your device requires it for the camera preview."
        }
      ],
      [
        "expo-updates",
        {
          "username": "ohanronnie",
          "channel": "production"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "./plugins/withUpdatesChannel.js",
        {
          "channel": "production"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c8e9edc6-e561-422c-b8bc-576d4ebc2c82",
        "channel": "production"
      }
    },
    "owner": "ohanronnie"
  }
}
